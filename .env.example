# @minitool/feishu-bot 环境变量模板
#
# 复制为 .env 后填入真实值：
#   cp .env.example .env
#
# .env 已被 .gitignore 忽略，请勿提交真实凭据。

# ─────────────────────────────────────────────
# 必填：自定义机器人 Webhook
# 在飞书群「设置 → 群机器人 → 添加 自定义机器人」中获取
# ─────────────────────────────────────────────
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 可选：签名校验密钥
# 仅当机器人安全设置开启了「签名校验」时才需要
# ─────────────────────────────────────────────
FEISHU_BOT_SECRET=

# ─────────────────────────────────────────────
# 可选：自建应用凭据（仅图片上传需要）
# 在飞书开放平台「开发者后台 → 凭证与基础信息」获取
# 如果只发送 text / post / interactive / share_chat，
# 或者已有 image_key 直发，可以留空
# ─────────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
